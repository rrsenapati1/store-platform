{
  "name": "store-platform",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:platform-admin": "npm run dev --workspace @store/platform-admin",
    "dev:owner-web": "npm run dev --workspace @store/owner-web",
    "dev:store-desktop": "npm run dev --workspace @store/store-desktop",
    "dev:store-desktop:tauri": "npm run tauri:dev --workspace @store/store-desktop",
    "dev:seed-local-demo": "python services/control-plane-api/scripts/seed_local_demo.py --api-origin http://127.0.0.1:18000",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "ci:backend": "python -m pytest services/control-plane-api/tests -q",
    "ci:platform-admin": "npm run test --workspace @store/platform-admin && npm run typecheck --workspace @store/platform-admin && npm run build --workspace @store/platform-admin",
    "ci:owner-web": "npm run test --workspace @store/owner-web && npm run typecheck --workspace @store/owner-web && npm run build --workspace @store/owner-web",
    "ci:store-mobile": "node scripts/run-store-mobile-gradle.mjs testDebugUnitTest",
    "ci:store-desktop": "npm run test --workspace @store/store-desktop && npm run typecheck --workspace @store/store-desktop && npm run build --workspace @store/store-desktop && cargo test --manifest-path apps/store-desktop/src-tauri/Cargo.toml --lib",
    "ci:release-automation": "node --test scripts/package-control-plane-release.test.mjs scripts/package-web-release.test.mjs scripts/stage-store-desktop-release-artifacts.test.mjs scripts/github-workflows.test.mjs scripts/generate-store-desktop-update-manifest.test.mjs",
    "release:control-plane": "node scripts/package-control-plane-release.mjs",
    "release:platform-admin": "node scripts/package-web-release.mjs --app platform-admin",
    "release:owner-web": "node scripts/package-web-release.mjs --app owner-web",
    "release:store-desktop:stage": "node scripts/stage-store-desktop-release-artifacts.mjs"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "jsdom": "^27.2.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vitest": "^3.2.4"
  }
}
