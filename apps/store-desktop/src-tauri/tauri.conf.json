{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Store Runtime",
  "version": "0.1.0",
  "identifier": "com.korsenex.store-desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Store Runtime",
        "width": 1600,
        "height": 960,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
