STORE_CONTROL_PLANE_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:54321/store_control_plane
STORE_CONTROL_PLANE_DEPLOYMENT_ENVIRONMENT=dev
STORE_CONTROL_PLANE_PUBLIC_BASE_URL=http://127.0.0.1:8000
STORE_CONTROL_PLANE_RELEASE_VERSION=dev
STORE_CONTROL_PLANE_KORSENEX_IDP_MODE=jwks
STORE_CONTROL_PLANE_KORSENEX_IDP_JWKS_URL=https://id.korsenex.local/.well-known/jwks.json
STORE_CONTROL_PLANE_KORSENEX_IDP_ISSUER=https://id.korsenex.local
STORE_CONTROL_PLANE_KORSENEX_IDP_AUDIENCE=store-control-plane
STORE_CONTROL_PLANE_LEGACY_WRITE_MODE=shadow
STORE_CONTROL_PLANE_PLATFORM_ADMIN_EMAILS=admin@store.local,ops@store.local
STORE_CONTROL_PLANE_OBJECT_STORAGE_ENDPOINT_URL=
STORE_CONTROL_PLANE_OBJECT_STORAGE_REGION=
STORE_CONTROL_PLANE_OBJECT_STORAGE_BUCKET=
STORE_CONTROL_PLANE_OBJECT_STORAGE_PREFIX=store-control-plane/dev
STORE_CONTROL_PLANE_OBJECT_STORAGE_ACCESS_KEY_ID=
STORE_CONTROL_PLANE_OBJECT_STORAGE_SECRET_ACCESS_KEY=
STORE_CONTROL_PLANE_OBJECT_STORAGE_SESSION_TOKEN=
STORE_CONTROL_PLANE_OBJECT_STORAGE_FORCE_PATH_STYLE=false
STORE_CONTROL_PLANE_BACKUP_ARTIFACT_PREFIX=postgres-backups
STORE_CONTROL_PLANE_RESTORE_ARTIFACT_PREFIX=restore-drills
STORE_CONTROL_PLANE_DESKTOP_RELEASE_ARTIFACT_PREFIX=desktop-releases
STORE_CONTROL_PLANE_BACKUP_RETENTION_DAYS=14
STORE_CONTROL_PLANE_SENTRY_DSN=
STORE_CONTROL_PLANE_SENTRY_TRACES_SAMPLE_RATE=0.0
STORE_CONTROL_PLANE_SENTRY_ENVIRONMENT=
STORE_CONTROL_PLANE_LOG_FORMAT=plain
STORE_CONTROL_PLANE_RATE_LIMIT_WINDOW_SECONDS=60
STORE_CONTROL_PLANE_RATE_LIMIT_AUTH_REQUESTS=10
STORE_CONTROL_PLANE_RATE_LIMIT_ACTIVATION_REQUESTS=10
STORE_CONTROL_PLANE_RATE_LIMIT_WEBHOOK_REQUESTS=30
STORE_CONTROL_PLANE_SECURE_HEADERS_ENABLED=true
STORE_CONTROL_PLANE_SECURE_HEADERS_HSTS_ENABLED=false
STORE_CONTROL_PLANE_SECURE_HEADERS_CSP=default-src 'self'; frame-ancestors 'none'; base-uri 'self'
